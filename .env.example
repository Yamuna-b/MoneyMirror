# Money Mirror — copy to `.env` and adjust

# development | production  (production requires MM_SECRET_KEY >= 32 chars)
MM_ENV=development
MM_SECRET_KEY=change-me-in-production

# SQLite (default) or Postgres, e.g. postgresql+psycopg2://user:pass@host/db
MM_DATABASE_URL=sqlite:///./money_mirror.db

# Comma-separated origins (no spaces). Use * only in local dev.
MM_CORS_ORIGINS=http://localhost:8000,http://127.0.0.1:8000

# Opinionated defaults
MM_DEFAULT_HORIZON_MONTHS=12
MM_SAFETY_TARGET_MONTHS=6
MM_DEFAULT_MIN_BALANCE=10000

# Risk bands (emergency fund = months of expenses covered by current savings)
MM_EF_MONTHS_HIGH=3
MM_EF_MONTHS_CAUTION=6

# Debt-to-income (EMI / gross income)
MM_DTI_HIGH=0.50
MM_DTI_CAUTION=0.40

# Runway = months before balance dips below minimum comfortable level
MM_RUNWAY_MONTHS_HIGH=2
MM_RUNWAY_MONTHS_CAUTION=4

# Copy / advice text
MM_EF_RECOMMENDED_MIN=3

# JWT lifetime (minutes). Default 7 days.
MM_ACCESS_TOKEN_MINUTES=10080

# Simulation history pagination
MM_HISTORY_DEFAULT_LIMIT=10
MM_HISTORY_MAX_LIMIT=50
